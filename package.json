{
    "name": "skipthevoice-monorepo",
    "version": "0.1.2",
    "type": "module",
    "workspaces": [
        "apps/web",
        "packages/*"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "prepublishOnly": "node -e \"console.error('Refusing to publish the monorepo root. Use: npm run publish:npm -- --publish'); process.exit(1)\"",
        "postinstall": "npm run build -w @skipthevoice/core && npm run build -w skipthevoice",
        "dev": "concurrently -k -n web,runner,whisper 'npm run dev:web' 'npm run dev:worker' 'npm run dev:whisper'",
        "dev:web": "npm run dev -w @skipthevoice/web",
        "dev:worker": "tsx packages/core/src/transcription/runner-entry.ts",
        "dev:whisper": ".venv/bin/python -m uvicorn app.main:app --app-dir apps/whisper-worker --host 0.0.0.0 --port 8090",
        "build": "npm run build -w @skipthevoice/core && npm run build -w skipthevoice",
        "start": "npm run start -w @skipthevoice/web",
        "start:worker": "node packages/core/dist/transcription/runner-entry.js",
        "worker": "tsx packages/core/src/transcription/runner-entry.ts",
        "cli": "tsx packages/cli/src/index.ts",
        "cli:dev": "tsx packages/cli/src/index.ts",
        "lint": "npm run lint -w @skipthevoice/web && eslint packages/core/src packages/cli/src",
        "typecheck": "npm run build -w @skipthevoice/core && tsc -p packages/cli/tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit",
        "test": "vitest run",
        "test:integration": "vitest run packages/core/src/**/*.integration.test.ts",
        "test:e2e": "playwright test",
        "test:cli": "vitest run packages/cli",
        "db:seed": "npm run cli -- db seed",
        "db:backup": "npm run cli -- db backup",
        "whisper:install": "python3.12 -m venv .venv && .venv/bin/python -m pip install -r apps/whisper-worker/requirements.txt",
        "whisper:test": "PYTHONPATH=apps/whisper-worker .venv/bin/python -m pytest apps/whisper-worker/app/tests",
        "pack:cli": "npm pack -w skipthevoice",
        "publish:npm": "node scripts/publish-npm.mjs",
        "release:brew": "node scripts/update-homebrew-formula.mjs"
    },
    "devDependencies": {
        "@eslint/js": "9.31.0",
        "@playwright/test": "1.61.1",
        "@types/better-sqlite3": "7.6.13",
        "@types/node": "24.0.15",
        "concurrently": "9.2.0",
        "eslint": "9.31.0",
        "tsx": "4.20.3",
        "typescript": "5.9.2",
        "typescript-eslint": "8.64.0",
        "vitest": "4.1.10"
    },
    "overrides": {
        "postcss": "8.5.10",
        "next": {
            "postcss": "8.5.10"
        }
    }
}

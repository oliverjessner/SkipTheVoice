NODE_ENV=development
APP_BASE_URL=http://localhost:3000
DEFAULT_USER_ID=dev-user
DATABASE_URL=file:./data/database/skipthevoice.db
DATA_DIRECTORY=./data
AUDIO_DIRECTORY=./data/audio
MESSENGER_CREDENTIALS_DIRECTORY=./data/credentials
EXPORT_DIRECTORY=./data/exports
SQLITE_BUSY_TIMEOUT_MS=5000
WHISPER_WORKER_URL=http://localhost:8090
WHISPER_WORKER_INTERNAL_TOKEN=change-me
WHISPER_MODEL=turbo
WHISPER_DEVICE=auto
WHISPER_LANGUAGE=
WHISPER_TASK=transcribe
WHISPER_MAX_CONCURRENT_JOBS=1
WHISPER_MOCK=false
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
MAX_AUDIO_FILE_SIZE_MB=25
MAX_AUDIO_DURATION_SECONDS=1800
TRANSCRIPTION_PROGRESS_PERSIST_INTERVAL_MS=500
TRANSCRIPTION_STALE_AFTER_SECONDS=120
TRANSCRIPTION_ETA_MINIMUM_SAMPLES=4
TRANSCRIPTION_ETA_SMOOTHING_ALPHA=0.25
LOG_LEVEL=info
